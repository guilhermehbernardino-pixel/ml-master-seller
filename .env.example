# =============================================================
# ML MASTER AFILIADO - Configurações
# Copie este arquivo para .env e preencha suas credenciais
# =============================================================

# === MERCADO LIVRE ===
ML_EMAIL=seu_email@gmail.com
ML_PASSWORD=sua_senha_ml
ML_AFFILIATE_TAG=begu5752228

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=seu_token_do_bot
TELEGRAM_CHANNEL_ID=-1001234567890

# === CLAUDE API (para geração de conteúdo) ===
ANTHROPIC_API_KEY=sua_chave_anthropic

# === CONFIGURAÇÕES DO BOT ===
# Intervalo mínimo entre posts (segundos)
MIN_POST_INTERVAL=1800
# Intervalo máximo entre posts (segundos)  
MAX_POST_INTERVAL=3600
# Quantidade de produtos por rodada
PRODUCTS_PER_ROUND=10
# Comissão mínima para publicar (%)
MIN_COMMISSION=5

# === DASHBOARD ===
DASHBOARD_PORT=8080
DASHBOARD_SECRET=mlmaster_secret_2025

# === WHATSAPP (Evolution API - Docker) ===
# IMPORTANTE: Use uma porta diferente do Dashboard (8080)
# docker run -d --name evolution -p 8888:8080 atendai/evolution-api
WHATSAPP_API_URL=http://localhost:8888
WHATSAPP_API_KEY=sua_chave_evolution
WHATSAPP_INSTANCE=meu-afiliado
WA_MY_NUMBER=5511999999999
WA_GROUP_GERAL=ID_DO_GRUPO@g.us
